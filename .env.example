# Scam Slayer — environment variables (copy to .env; .env is gitignored)
# Every key is OPTIONAL. With none set, the app runs in DEMO mode (full flow,
# mock data, no wallet) and LIVE mode works once you enter keys in Settings.

# --- Live AI + chain data (or enter these in the app's Settings instead) ---
# Venice AI — https://venice.ai
VITE_VENICE_API_KEY=
# Alchemy — https://alchemy.com (best for live approval scanning)
VITE_ALCHEMY_API_KEY=
# Etherscan v2 — https://etherscan.io/apis (contract age + verification)
VITE_ETHERSCAN_API_KEY=
# Pimlico — https://pimlico.io (bundler, for delegated revocation UserOps)
VITE_PIMLICO_API_KEY=
# Infura — optional; enables wide eth_getLogs ranges. Unset → keyless public RPCs.
VITE_INFURA_KEY=

# --- Secret proxy (recommended for a public deploy) ---
# Deployed Cloudflare Worker (see worker/). When set, Venice/RPC/Etherscan route
# through it and NO keys are baked into the client bundle.
VITE_PROXY_URL=

# --- Modes / defaults (optional) ---
VITE_X402_ENABLED=
VITE_CHAIN_ID=
VITE_RELAYER_MODE=
VITE_RELAYER_WEBHOOK=

# --- Per-chain RPC overrides (optional) ---
# VITE_SEPOLIA_RPC=
# VITE_MAINNET_RPC=
# VITE_BASE_RPC=
